<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="317.0" prefWidth="299.0" spacing="8.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.energyjavafxgui.HelloController">
  <padding>
    <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
  </padding>

  <Label fx:id="labelCommunityPool" alignment="CENTER" text="Community Pool">
      <opaqueInsets>
         <Insets />
      </opaqueInsets></Label>
   <Label fx:id="labelGridPortion" prefWidth="103.0" text="Grid Portion" />
  <Button onAction="#onRefreshClick" text="refresh" />
   <GridPane>
     <columnConstraints>
       <ColumnConstraints hgrow="SOMETIMES" minWidth="40.0" />
       <ColumnConstraints hgrow="SOMETIMES" maxWidth="1.7976931348623157E308" minWidth="10.0" />
     </columnConstraints>
     <rowConstraints>
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
       <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
     </rowConstraints>
      <children>
         <Label text="Start" />
         <DatePicker fx:id="start" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" />
         <Label text="End" GridPane.rowIndex="1" />
         <DatePicker fx:id="end" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
      </children>
      <VBox.margin>
         <Insets right="10.0" />
      </VBox.margin>
   </GridPane>
   <Button onAction="#onShowDataClick" mnemonicParsing="false" text="show data">
      <VBox.margin>
         <Insets bottom="10.0" />
      </VBox.margin></Button>
   <Label fx:id="labelCommunityProduced" text="Community produced" />
   <Label fx:id="labelCommunityUsed" text="Community used" />
   <Label fx:id="labelGridUsed" text="Grid used" />
   <Label fx:id="labelError" />
   <opaqueInsets>
      <Insets />
   </opaqueInsets>
</VBox>
